{
  "name": "api-automation-framework",
  "version": "2.0.0",
  "description": "Enterprise API automation framework with CI/CD integration, Playwright, Cucumber BDD, and Allure reporting",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:smoke": "cucumber-js --profile smoke",
    "test:regression": "cucumber-js --profile regression",
    "test:parallel": "cucumber-js --parallel 2",
    "test:tags": "cucumber-js --tags",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run allure:generate && npm run allure:open",
    "clean": "rimraf allure-results allure-report test-results logs",
    "clean:all": "npm run clean && rimraf node_modules package-lock.json"
  },
  "keywords": [
    "api",
    "automation",
    "playwright",
    "cucumber",
    "bdd",
    "allure",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.42.1",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/register": "^7.23.7",
    "allure-commandline": "^2.27.0",
    "allure-cucumberjs": "^3.7.1",
    "allure-js-commons": "^3.7.1",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
